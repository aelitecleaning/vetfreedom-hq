# ─────────────────────────────────────────────────────────────────────────────
# Military to Financial Freedom — environment variables
# Copy to .env.local for local dev. In production these live ONLY in Netlify
# (Site settings → Environment variables). Never commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Launch switch: when true, every account is treated as a paid "Field Grade"
# member (free launch period). Flip to false to begin enforcing paid tiers.
FREE_FOR_ALL=true

# Supabase (auth + Postgres). ANON key is public; SERVICE_ROLE is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_FOUNDING=

# Claude API (AI Battle Buddy) — server-side only, never exposed to the client
ANTHROPIC_API_KEY=
# Optional: paste the MTFF book text here to give the AI reference knowledge for
# business/finance answers. Leave blank to run without it.
MTFF_BOOK_KNOWLEDGE=

# Resend (transactional + reminder email)
RESEND_API_KEY=
RESEND_FROM="Military to Financial Freedom <hq@militarytofinancialfreedom.com>"

# Community
NEXT_PUBLIC_SKOOL_URL=https://www.skool.com/
